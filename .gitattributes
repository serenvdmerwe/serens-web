# Normalize line endings to LF in the repo (important for Docker/Caddy/PHP configs
# that break with CRLF). Working copies can still check out platform endings.
* text=auto eol=lf

# Binary assets: never touch line endings.
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
