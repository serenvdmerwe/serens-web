{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "768px",
      "wideSize": "1240px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "custom": true,
      "customDuotone": false,
      "palette": [
        { "slug": "primary",        "name": "Primary (Orange)",   "color": "#F6821F" },
        { "slug": "primary-strong", "name": "Primary Strong",     "color": "#E5751A" },
        { "slug": "dark",           "name": "Dark",               "color": "#1A1A1A" },
        { "slug": "dark-2",         "name": "Dark 2",             "color": "#2A2A2A" },
        { "slug": "dark-3",         "name": "Dark 3 (Card)",      "color": "#232323" },
        { "slug": "smoke",          "name": "Smoke",              "color": "#F5F5F5" },
        { "slug": "smoke-2",        "name": "Smoke 2",            "color": "#E8E8E8" },
        { "slug": "white",          "name": "White",              "color": "#FCFCFB" },
        { "slug": "text-light",     "name": "Text Light",         "color": "#EDEBE7" },
        { "slug": "text-muted",     "name": "Text Muted",         "color": "#A8A6A2" },
        { "slug": "text-dark",      "name": "Text Dark",          "color": "#1A1A1A" },
        { "slug": "text-dark-2",    "name": "Text Dark Muted",    "color": "#5A5A58" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Geist",
          "fontFamily": "\"Geist\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
          "fontFace": [
            {
              "fontFamily": "Geist",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/Geist-Variable.ttf" ]
            }
          ]
        },
        {
          "slug": "mono",
          "name": "Geist Mono",
          "fontFamily": "\"Geist Mono\", ui-monospace, \"SF Mono\", Menlo, monospace",
          "fontFace": [
            {
              "fontFamily": "Geist Mono",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/GeistMono-Variable.ttf" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "caption",   "name": "Caption",   "size": "12.5px",                       "fluid": false },
        { "slug": "body",      "name": "Body",      "size": "16px",                         "fluid": false },
        { "slug": "lede",      "name": "Lede",      "size": "clamp(16px, 1.5cqi, 18.88px)" },
        { "slug": "h3",        "name": "H3",        "size": "clamp(19.5px, 2.0cqi, 23px)" },
        { "slug": "h2",        "name": "H2",        "size": "clamp(30px, 4.6cqi, 51px)" },
        { "slug": "h1",        "name": "H1",        "size": "clamp(41.6px, 8.4cqi, 86.4px)" }
      ]
    },
    "spacing": {
      "units": [ "px", "rem", "em", "%", "vw", "vh", "cqi" ],
      "spacingSizes": [
        { "slug": "1",  "name": "1 . 4",    "size": "4px"   },
        { "slug": "2",  "name": "2 . 8",    "size": "8px"   },
        { "slug": "3",  "name": "3 . 12",   "size": "12px"  },
        { "slug": "4",  "name": "4 . 16",   "size": "16px"  },
        { "slug": "5",  "name": "5 . 24",   "size": "24px"  },
        { "slug": "6",  "name": "6 . 32",   "size": "32px"  },
        { "slug": "7",  "name": "7 . 48",   "size": "48px"  },
        { "slug": "8",  "name": "8 . 64",   "size": "64px"  },
        { "slug": "9",  "name": "9 . 96",   "size": "96px"  },
        { "slug": "10", "name": "10 . 128", "size": "128px" }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "custom": {
      "radius": {
        "sm":   "8px",
        "md":   "14px",
        "lg":   "22px",
        "pill": "999px"
      },
      "shadow": {
        "card": "0 1px 2px rgba(0,0,0,0.04), 0 12px 32px -12px rgba(0,0,0,0.16)",
        "pop":  "0 24px 70px -24px rgba(0,0,0,0.45)"
      },
      "motion": {
        "ease": "cubic-bezier(0.22, 1, 0.36, 1)",
        "dur":  "0.55s"
      },
      "maxWidth": "1240px",
      "gutter":   "clamp(20px, 5cqi, 56px)"
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "0"
    },
    "color": {
      "background": "var(--wp--preset--color--dark)",
      "text":       "var(--wp--preset--color--text-light)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize":   "16px",
      "lineHeight": "1.55"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily":    "var(--wp--preset--font-family--sans)",
          "fontWeight":    "600",
          "lineHeight":    "1.05",
          "letterSpacing": "-0.025em"
        }
      },
      "h1": { "typography": { "fontSize": "var(--wp--preset--font-size--h1)" } },
      "h2": { "typography": { "fontSize": "var(--wp--preset--font-size--h2)" } },
      "h3": { "typography": { "fontSize": "var(--wp--preset--font-size--h3)" } },
      "link": { "color": { "text": "var(--wp--preset--color--primary)" } }
    }
  },
  "templateParts": [
    { "name": "header", "area": "header", "title": "Header" },
    { "name": "footer", "area": "footer", "title": "Footer" }
  ],
  "customTemplates": [
    { "name": "page-home", "title": "Home", "postTypes": [ "page" ] }
  ]
}
