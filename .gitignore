# Secrets and local-only
.env
logs/
*.sql
*.sql.gz
caddy-root.crt

# Private ops notes (deploy recipe, server details, credentials). Local only, never pushed.
docs/private/

# WordPress core and uploads are not tracked. The child theme IS tracked,
# so each directory on the path is re-included before its contents are ignored.
wordpress/*
!wordpress/wp-content/
wordpress/wp-content/*
!wordpress/wp-content/themes/
wordpress/wp-content/themes/*
!wordpress/wp-content/themes/serensweb-child/

# Never track build artefacts or deps that might appear inside the theme.
wordpress/wp-content/themes/serensweb-child/node_modules/

# Theme zip is a build artefact rebuilt from the theme source on demand.
serensweb-child.zip
