# PHP-FPM container runs as this user. Must match the host user that owns
# the wordpress/ directory, otherwise plugin/media writes from inside the
# container will be owned by the wrong user.
#
# WSL/Linux:    set PUSER, PUID, PGID from `whoami`, `id -u`, `id -g`.
# Windows DD:   leave defaults — Docker Desktop translates ownership.
PUSER=semantica
PUID=1000
PGID=1000

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=serens_web
MYSQL_USER=serens
MYSQL_PASSWORD=

# Gmail SMTP for the contact form (docs/contact-email-setup.md). Leave blank to
# skip delivery; the form still validates and shows success. SW_SMTP_PASS is a
# Google App Password (16 chars), never the account password. SW_SMTP_FROM is
# optional and defaults to SW_SMTP_USER.
SW_SMTP_USER=
SW_SMTP_PASS=
SW_SMTP_FROM=
